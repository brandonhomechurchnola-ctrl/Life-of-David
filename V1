// ============ App ============
const STORAGE_KEY = "lifeOfDavid.progress.v3";

function load() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}"); } catch(e) { return {}; } }
function save(p) { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(p)); } catch(e) {} }
let progress = load();

const totalDays = () => PLAN.reduce((s, w) => s + w.days.length, 0);
const completedCount = () => Object.values(progress).filter(Boolean).length;

function todayDayNumber() {
  const total = totalDays();
  let n = 1;
  while (n <= total && progress[n]) n++;
  return Math.min(n, total);
}

function updateProgressBar() {
  const done = completedCount();
  document.getElementById("progress-count").textContent = done;
  document.getElementById("progress-fill").style.width = (done / totalDays() * 100) + "%";
}

function weekProgressText(w) {
  const done = w.days.filter(d => progress[d.day]).length;
  return done + " / " + w.days.length;
}

function render() {
  const container = document.getElementById("weeks-container");
  container.innerHTML = "";
  const today = todayDayNumber();
  const todayWeek = PLAN.find(w => w.days.some(d => d.day === today));

  PLAN.forEach(w => {
    const weekEl = document.createElement("section");
    weekEl.className = "week";
    weekEl.dataset.week = w.week;

    const header = document.createElement("div");
    header.className = "week-header";
    header.innerHTML = `
      <div class="week-meta">
        <div class="week-number">Week ${w.week}</div>
        <h2 class="week-title">${w.title}</h2>
      </div>
      <span class="week-progress">${weekProgressText(w)}</span>
      <span class="chevron">&#9656;</span>
    `;
    header.addEventListener("click", () => weekEl.classList.toggle("open"));
    weekEl.appendChild(header);

    const body = document.createElement("div");
    body.className = "week-body";
    w.days.forEach(d => {
      const isComplete = !!progress[d.day];
      const isToday = d.day === today;
      const dayEl = document.createElement("div");
      dayEl.className = "day" + (isComplete ? " complete" : "") + (isToday ? " today" : "");
      dayEl.id = "day-" + d.day;
      dayEl.innerHTML = `
        <div class="day-num">${d.day}</div>
        <div class="day-content">
          <div class="day-ref"><span class="day-tag">${isToday ? "Today" : "Day " + d.day}</span>${d.ref}</div>
          <p class="day-focus">${d.focus}</p>
          <div class="day-section">
            <span class="day-label">Reflect</span>
            <ul>${d.reflect.map(r => `<li>${r}</li>`).join("")}</ul>
          </div>
          <div class="day-section pray">
            <span class="day-label">Pray</span>
            <p>${d.pray}</p>
          </div>
        </div>
        <button class="check-btn" data-check="${d.day}">${isComplete ? "✓ Done" : "Mark done"}</button>
      `;
      body.appendChild(dayEl);
    });
    weekEl.appendChild(body);
    if (todayWeek && w.week === todayWeek.week) weekEl.classList.add("open");
    container.appendChild(weekEl);
  });

  container.querySelectorAll("[data-check]").forEach(btn => {
    btn.addEventListener("click", e => {
      e.stopPropagation();
      const day = parseInt(btn.dataset.check, 10);
      progress[day] = !progress[day];
      if (!progress[day]) delete progress[day];
      save(progress);
      render();
    });
  });

  updateProgressBar();
}

document.getElementById("jump-today").addEventListener("click", () => {
  const today = todayDayNumber();
  const tw = PLAN.find(w => w.days.some(d => d.day === today));
  if (tw) {
    document.querySelectorAll(".week").forEach(el => {
      if (parseInt(el.dataset.week, 10) === tw.week) el.classList.add("open");
    });
  }
  setTimeout(() => {
    const el = document.getElementById("day-" + today);
    if (el) el.scrollIntoView({ behavior: "smooth", block: "center" });
  }, 50);
});
document.getElementById("expand-all").addEventListener("click", () => {
  document.querySelectorAll(".week").forEach(el => el.classList.add("open"));
});
document.getElementById("collapse-all").addEventListener("click", () => {
  document.querySelectorAll(".week").forEach(el => el.classList.remove("open"));
});
document.getElementById("reset-progress").addEventListener("click", () => {
  if (confirm("Reset all your progress?")) {
    progress = {};
    save(progress);
    render();
  }
});

render();
</script>
